# Which LLM to use for reranking. Options: openai, anthropic, gemini
LLM_PROVIDER=openai

# API keys — only the one matching LLM_PROVIDER is required
OPENAI_API_KEY=your-key-here
ANTHROPIC_API_KEY=your-key-here
GEMINI_API_KEY=your-key-here

# Set to "true" to skip LLM reranking and return raw retrieval order.
# Useful for debugging retrieval without having to burn API credits.
SKIP_RERANK=false
